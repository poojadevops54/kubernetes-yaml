FROM alpine:latest

# Install Apache
RUN apk update && apk add --no-cache apache2

# Create required directories
RUN mkdir -p /run/apache2

# Set working directory
WORKDIR /var/www/localhost/htdocs/

# Copy index file
COPY index.html .

# Expose port
EXPOSE 80

# Start Apache in foreground
CMD ["/usr/sbin/httpd", "-D", "FOREGROUND"]
